{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "search-status-menu",
  "title": "Search Status Menu",
  "description": "Fuzzy search and interact with macOS status menu (menubar) items via keyboard",
  "icon": "🔍",
  "author": "loudog",
  "categories": [
    "Productivity",
    "System"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "search-status-menu",
      "title": "Search Status Menu",
      "description": "Fuzzy search and interact with macOS status menu items",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.83.2",
    "@raycast/utils": "^1.17.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.11",
    "@types/node": "20.8.10",
    "@types/react": "^19.2.14",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "build-helper": "cd swift-helper && ./build.sh",
    "publish": "npx @raycast/api@latest publish"
  }
}
